# Copy this file to .env and fill in your values
# python-dotenv will load it automatically

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: openai | ollama
LLM_BACKEND=openai

# OpenAI / DeepSeek / any OpenAI-compatible API
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1

# DeepSeek example:
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1

# Ollama example (no API key needed):
# LLM_BACKEND=ollama
# LLM_MODEL=deepseek-coder:33b
# LLM_BASE_URL=http://localhost:11434/v1

# ── Inference settings ────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512

# Few-shot examples (0 = zero-shot)
FEW_SHOT_K=5

# Schema top-K tables retrieved by MiniLM
SCHEMA_TOP_K=10

# Self-consistency candidates (1 = disabled, 5+ for best accuracy)
SELF_CONSISTENCY_N=1
SELF_CONSISTENCY_TEMP=0.7

# ── Embedding ─────────────────────────────────────────────────────────────────
# Options: FP16-Full | MP-Conservative | MP-Balanced | MP-Aggressive | INT8-Full
EMBED_PROFILE=MP-Balanced
EMBED_DEVICE=cpu
